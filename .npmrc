# pnpm strict-isolation by default — keeps Next.js apps with their own
# react/next copies (the "two-react" bug we hit when fully hoisted).
# Hoist only the Expo + React Native + Metro tooling so the RN gradle
# plugin can resolve its deps when EAS Build copies apps/mobile.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=babel-preset-expo
