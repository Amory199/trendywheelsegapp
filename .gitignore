*.apk
*.aab

# iOS
*.ipa

# Firebase client config — public repo, so these stay local. For EAS CI builds,
# upload them once via `eas secret:create --type file --name GOOGLE_SERVICES_JSON ...`
# and `eas secret:create --type file --name GOOGLE_SERVICES_INFO_PLIST ...`.
apps/mobile/GoogleService-Info.plist
apps/mobile/google-services.json
.claude/

# Graphify — generated artifacts (regen with `graphify update .` for code-only,
# or full re-extract via `/graphify .` in Claude Code). GRAPH_REPORT.md is
# committed as a human-readable snapshot.
graphify-out/*
!graphify-out/GRAPH_REPORT.md
