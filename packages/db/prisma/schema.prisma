// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────

enum AccountType {
  customer
  staff
  admin
}

enum UserStatus {
  active
  inactive
  suspended
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum StaffRole {
  admin
  sales
  support
  inventory
  mechanic
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

enum LeadSource {
  signup
  rent_inquiry  @map("rent-inquiry")
  sell_inquiry  @map("sell-inquiry")
  repair_inquiry @map("repair-inquiry")
  manual
  imported
}

model User {
  id            String      @id @default(uuid()) @db.Uuid
  phone         String      @unique
  email         String?     @unique
  name          String      @default("")
  avatarUrl     String?     @map("avatar_url")
  accountType   AccountType @default(customer) @map("account_type")
  status        UserStatus  @default(active)
  preferences   Json?
  loyaltyTier   LoyaltyTier @default(bronze) @map("loyalty_tier")
  loyaltyPoints Int         @default(0) @map("loyalty_points")
  passwordHash  String?     @map("password_hash")
  totpSecret    String?     @map("totp_secret")
  licenseNumber  String?    @map("license_number")
  licenseExpiry  DateTime?  @map("license_expiry")
  licensePhotoUrl String?   @map("license_photo_url")
  staffRole          StaffRole? @map("staff_role")
  salesTargetMonthly Decimal?   @map("sales_target_monthly") @db.Decimal(12, 2)
  salesAssignmentWeight Int     @default(1) @map("sales_assignment_weight")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  bookings         Booking[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  repairRequests   RepairRequest[] @relation("UserRepairs")
  assignedRepairs  RepairRequest[] @relation("MechanicRepairs")
  salesListings    SalesListing[]
  supportTickets   SupportTicket[] @relation("UserTickets")
  assignedTickets  SupportTicket[] @relation("AgentTickets")
  refreshTokens    RefreshToken[]
  otpCodes         OtpCode[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  loyaltyTxns      LoyaltyTransaction[]
  conditionReports VehicleConditionReport[] @relation("ConditionReporter")
  conversationParticipants ConversationParticipant[]
  customerNotes    CustomerNote[]           @relation("CustomerNotes")
  authoredNotes    CustomerNote[]           @relation("AuthorNotes")
  ownedLeads       Lead[]                    @relation("LeadOwner")
  customerLead     Lead?                     @relation("LeadCustomer")
  leadActivities   LeadActivity[]            @relation("LeadActivityActor")
  reviews          Review[]
  referralCode     ReferralCode?
  referralsMade    Referral[]                @relation("ReferralReferrer")
  referralReceived Referral?                 @relation("ReferralReferee")
  promoRedemptions PromoRedemption[]
  broadcasts       Broadcast[]               @relation("BroadcastAuthor")
  cannedReplies    CannedReply[]
  salesTargets     SalesTarget[]

  @@map("users")
}

// ─── Auth ────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@map("otp_codes")
}

// ─── Vehicles ────────────────────────────────────────────────

enum VehicleType {
  FOUR_SEATER @map("4-seater")
  SIX_SEATER  @map("6-seater")
  LED
}

enum FuelType {
  electric
  gasoline
  hybrid
}

enum Transmission {
  automatic
  manual
}

enum VehicleStatus {
  available
  rented
  maintenance
  inactive
}

model Vehicle {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  type          VehicleType
  seating       Int
  fuelType      FuelType      @map("fuel_type")
  transmission  Transmission
  dailyRate     Decimal       @map("daily_rate") @db.Decimal(10, 2)
  location      String
  status        VehicleStatus @default(available)
  totalBookings Int           @default(0) @map("total_bookings")
  averageRating Decimal       @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount   Int           @default(0) @map("review_count")
  features      Json          @default("[]")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  images           VehicleImage[]
  bookings         Booking[]
  repairRequests   RepairRequest[]
  maintenanceLogs  VehicleMaintenance[]
  conditionReports VehicleConditionReport[]
  alertEvents      AlertEvent[]
  reviews          Review[]

  @@index([status])
  @@index([type])
  @@map("vehicles")
}

model VehicleImage {
  id        String   @id @default(uuid()) @db.Uuid
  vehicleId String   @map("vehicle_id") @db.Uuid
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_images")
}

// ─── Bookings ────────────────────────────────────────────────

enum BookingStatus {
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  refunded
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  vehicleId     String        @map("vehicle_id") @db.Uuid
  startDate     DateTime      @map("start_date") @db.Date
  endDate       DateTime      @map("end_date") @db.Date
  status        BookingStatus @default(confirmed)
  totalCost     Decimal       @map("total_cost") @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  promoCode      String?    @map("promo_code")
  promoDiscount  Decimal?   @map("promo_discount") @db.Decimal(10, 2)
  loyaltyPointsRedeemed Int @default(0) @map("loyalty_points_redeemed")
  loyaltyDiscount Decimal?  @map("loyalty_discount") @db.Decimal(10, 2)

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  review  Review?
  promoRedemption PromoRedemption?

  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("bookings")
}

// ─── Messages ────────────────────────────────────────────────

model Conversation {
  id            String   @id @default(uuid()) @db.Uuid
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(uuid()) @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  recipientId    String   @map("recipient_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  message        String
  attachments    Json     @default("[]")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  recipient    User         @relation("ReceivedMessages", fields: [recipientId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([recipientId])
  @@map("messages")
}

// ─── Repair Requests ─────────────────────────────────────────

enum RepairCategory {
  mechanical
  electrical
  cosmetic
  other
}

enum RepairPriority {
  low
  medium
  high
  urgent
}

enum RepairStatus {
  submitted
  assigned
  in_progress @map("in-progress")
  completed
  cancelled
}

model RepairRequest {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  vehicleId          String         @map("vehicle_id") @db.Uuid
  description        String
  category           RepairCategory
  priority           RepairPriority
  status             RepairStatus   @default(submitted)
  assignedMechanicId String?        @map("assigned_mechanic_id") @db.Uuid
  estimatedCost      Decimal?       @map("estimated_cost") @db.Decimal(10, 2)
  actualCost         Decimal?       @map("actual_cost") @db.Decimal(10, 2)
  preferredDate      DateTime?      @map("preferred_date")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user     User    @relation("UserRepairs", fields: [userId], references: [id])
  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  mechanic User?   @relation("MechanicRepairs", fields: [assignedMechanicId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@map("repair_requests")
}

// ─── Sales Listings ──────────────────────────────────────────

enum ListingStatus {
  active
  sold
  pending
}

model SalesListing {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  title          String
  make           String
  model          String
  year           Int
  mileage        Int
  price          Decimal       @db.Decimal(10, 2)
  transmission   Transmission
  fuelType       FuelType      @map("fuel_type")
  color          String
  description    String
  images         Json          @default("[]")
  status         ListingStatus @default(active)
  viewsCount     Int           @default(0) @map("views_count")
  inquiriesCount Int           @default(0) @map("inquiries_count")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([price])
  @@map("sales_listings")
}

// ─── Support ─────────────────────────────────────────────────

enum TicketStatus {
  open
  in_progress @map("in-progress")
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

model SupportTicket {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  subject        String
  status         TicketStatus   @default(open)
  priority       TicketPriority @default(medium)
  assignedAgentId String?       @map("assigned_agent_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user  User  @relation("UserTickets", fields: [userId], references: [id])
  agent User? @relation("AgentTickets", fields: [assignedAgentId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("support_tickets")
}

model KBArticle {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  content      String
  category     String
  viewsCount   Int      @default(0) @map("views_count")
  helpfulCount Int      @default(0) @map("helpful_count")
  searchVector Unsupported("tsvector")? @map("search_vector")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("kb_articles")
}

// ─── Vehicle Maintenance ─────────────────────────────────────

model VehicleMaintenance {
  id          String   @id @default(uuid()) @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  type        String
  description String?
  scheduledAt DateTime @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  cost        Decimal? @db.Decimal(10, 2)
  notes       String?
  photos      Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([scheduledAt])
  @@map("vehicle_maintenance")
}

// ─── Notifications ───────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

// ─── Audit Logging ───────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  actingAsId  String?  @map("acting_as_id") @db.Uuid
  action      String
  entity      String
  entityId    String?  @map("entity_id")
  metadata    Json?
  diff        Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actingAsId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Loyalty ─────────────────────────────────────────────────

model LoyaltyTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  points    Int
  type      String   // "earned", "redeemed", "expired"
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("loyalty_transactions")
}

model SystemConfig {
  id              String   @id @default(uuid()) @db.Uuid
  companyName     String   @default("TrendyWheels") @map("company_name")
  companyEmail    String?  @map("company_email")
  companyPhone    String?  @map("company_phone")
  companyAddress  String?  @map("company_address")
  companyHours    String?  @map("company_hours")
  currency        String   @default("EGP")
  taxRatePct      Decimal  @default(14.0) @db.Decimal(5, 2) @map("tax_rate_pct")
  emailTemplates  Json     @default("{}") @map("email_templates")
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedById     String?  @map("updated_by_id") @db.Uuid

  @@map("system_config")
}

model CrmRules {
  id                       String   @id @default(uuid()) @db.Uuid
  firstCallWithinMinutes   Int      @default(30)  @map("first_call_within_minutes")
  followUpCallWithinHours  Int      @default(24)  @map("follow_up_call_within_hours")
  reassignAfterHours       Int      @default(48)  @map("reassign_after_hours")
  maxReassignmentsBeforeEscalation Int @default(2) @map("max_reassignments_before_escalation")
  notifyOnAssignment       Boolean  @default(true) @map("notify_on_assignment")
  notifyOnEscalation       Boolean  @default(true) @map("notify_on_escalation")
  enforceRules             Boolean  @default(true) @map("enforce_rules")
  updatedAt                DateTime @updatedAt   @map("updated_at")
  updatedById              String?  @map("updated_by_id") @db.Uuid

  @@map("crm_rules")
}

model AlertConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  utilizationMaxPct    Int      @default(80) @map("utilization_max_pct")
  maintenanceDueDays   Int      @default(7)  @map("maintenance_due_days")
  maxConcurrentRepairs Int      @default(5)  @map("max_concurrent_repairs")
  updatedAt            DateTime @updatedAt   @map("updated_at")
  updatedById          String?  @map("updated_by_id") @db.Uuid

  @@map("alert_config")
}

model VehicleConditionReport {
  id          String   @id @default(uuid()) @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  reporterId  String   @map("reporter_id") @db.Uuid
  notes       String
  photos      Json     @default("[]")
  severity    String   @default("minor")
  createdAt   DateTime @default(now()) @map("created_at")

  vehicle  Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reporter User    @relation("ConditionReporter", fields: [reporterId], references: [id])

  @@index([vehicleId, createdAt])
  @@map("vehicle_condition_reports")
}

model CustomerNote {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  customer User @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  author   User @relation("AuthorNotes", fields: [authorId], references: [id])

  @@index([customerId, createdAt])
  @@map("customer_notes")
}

// ─── CRM / Sales Cycle ───────────────────────────────────────

model Lead {
  id                String      @id @default(uuid()) @db.Uuid
  customerId        String?     @unique @map("customer_id") @db.Uuid
  contactName       String      @map("contact_name")
  contactPhone      String?     @map("contact_phone")
  contactEmail      String?     @map("contact_email")
  source            LeadSource  @default(signup)
  status            LeadStatus  @default(new)
  estimatedValue    Decimal     @default(0) @map("estimated_value") @db.Decimal(12, 2)
  notes             String?
  ownerId           String?     @map("owner_id") @db.Uuid
  assignedAt        DateTime?   @map("assigned_at")
  claimDeadline     DateTime?   @map("claim_deadline")
  lastActivityAt    DateTime    @default(now()) @map("last_activity_at")
  lastCallAt        DateTime?   @map("last_call_at")
  callCount         Int         @default(0) @map("call_count")
  escalationLevel   Int         @default(0) @map("escalation_level")
  reassignmentCount Int         @default(0) @map("reassignment_count")
  closedAt          DateTime?   @map("closed_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  customer    User?           @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  owner       User?           @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities  LeadActivity[]

  @@index([ownerId])
  @@index([status])
  @@index([claimDeadline])
  @@index([lastActivityAt])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  type      String   // "created" | "assigned" | "reassigned" | "status-change" | "note" | "call" | "email" | "won" | "lost"
  body      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User? @relation("LeadActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

model AlertEvent {
  id         String    @id @default(uuid()) @db.Uuid
  type       String
  severity   String    @default("warning")
  message    String
  vehicleId  String?   @map("vehicle_id") @db.Uuid
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([resolvedAt])
  @@index([createdAt])
  @@map("alert_events")
}

// ─── God Mode: promo codes, pricing, broadcasts, business config ─────────────

model PromoCode {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  kind         String    // "percent" | "fixed"
  value        Decimal   @db.Decimal(10, 2)
  appliesTo    String    @map("applies_to") // "booking" | "sale" | "both"
  usageLimit   Int?      @map("usage_limit")
  usedCount    Int       @default(0) @map("used_count")
  expiresAt    DateTime? @map("expires_at")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")

  redemptions  PromoRedemption[]

  @@index([active, expiresAt])
  @@map("promo_codes")
}

model PromoRedemption {
  id              String   @id @default(uuid()) @db.Uuid
  promoId         String   @map("promo_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  bookingId       String?  @unique @map("booking_id") @db.Uuid
  salesListingId  String?  @map("sales_listing_id") @db.Uuid
  discountAmount  Decimal  @map("discount_amount") @db.Decimal(10, 2)
  redeemedAt      DateTime @default(now()) @map("redeemed_at")

  promo   PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])
  booking Booking?  @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([promoId])
  @@map("promo_redemptions")
}

model PricingRule {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  kind         String   // "weekend" | "peak" | "holiday" | "blackout"
  surchargePct Decimal  @map("surcharge_pct") @db.Decimal(5, 2)
  daysOfWeek   Int[]    @map("days_of_week")
  dateRanges   Json     @default("[]") @map("date_ranges")
  appliesTo    String   @map("applies_to") // "rent" | "sell" | "both"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("pricing_rules")
}

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  channel   String   // "push" | "email" | "sms"
  subject   String?
  bodyMd    String   @map("body_md")
  variables Json     @default("[]")
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model Broadcast {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  bodyMd      String    @map("body_md")
  audience    String    // "all" | "customers" | "staff" | "tier:gold" | "city:Marassi"
  channels    String[]  @default(["push"])
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  sentCount   Int       @default(0) @map("sent_count")
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  createdBy User @relation("BroadcastAuthor", fields: [createdById], references: [id])

  @@index([scheduledAt])
  @@index([sentAt])
  @@map("broadcasts")
}

model CannedReply {
  id          String   @id @default(uuid()) @db.Uuid
  label       String
  bodyMd      String   @map("body_md")
  category    String?
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("canned_replies")
}

model BusinessHours {
  id         String  @id @default(uuid()) @db.Uuid
  dayOfWeek  Int     @map("day_of_week") // 0 = Sunday
  openHHMM   String  @map("open_hhmm")   // "08:00"
  closeHHMM  String  @map("close_hhmm")  // "22:00"
  locationId String? @map("location_id")
  active     Boolean @default(true)

  @@unique([dayOfWeek, locationId])
  @@map("business_hours")
}

model Holiday {
  id     String   @id @default(uuid()) @db.Uuid
  date   DateTime @db.Date
  name   String
  closed Boolean  @default(true)

  @@unique([date])
  @@map("holidays")
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model SalesTarget {
  id            String   @id @default(uuid()) @db.Uuid
  agentId       String   @map("agent_id") @db.Uuid
  targetMonthly Decimal  @map("target_monthly") @db.Decimal(12, 2)
  month         DateTime @db.Date
  commissionPct Decimal  @default(0) @map("commission_pct") @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  agent User @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, month])
  @@index([month])
  @@map("sales_targets")
}

// ─── Customer features: reviews, referrals ───────────────────────────────────

model Review {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  vehicleId     String   @map("vehicle_id") @db.Uuid
  bookingId     String   @unique @map("booking_id") @db.Uuid
  rating        Int      // 1-5
  title         String?
  body          String?
  photos        Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")
  editableUntil DateTime @map("editable_until")

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([vehicleId])
  @@index([userId])
  @@map("reviews")
}

model ReferralCode {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @unique @map("user_id") @db.Uuid
  code      String @unique
  usedCount Int    @default(0) @map("used_count")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("referral_codes")
}

model Referral {
  id          String    @id @default(uuid()) @db.Uuid
  referrerId  String    @map("referrer_id") @db.Uuid
  refereeId   String    @unique @map("referee_id") @db.Uuid
  codeUsed    String    @map("code_used")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  rewardPaid  Boolean   @default(false) @map("reward_paid")

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referee  User @relation("ReferralReferee", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([completedAt])
  @@map("referrals")
}

model ErrorLog {
  id         String    @id @default(uuid()) @db.Uuid
  level      String // "error" | "warn" | "fatal"
  source     String // "api" | "worker" | "socket" | "process" | "admin" | "support" | "inventory" | "customer" | "mobile"
  message    String
  stack      String?   @db.Text
  route      String?
  method     String?
  statusCode Int?      @map("status_code")
  userId     String?   @map("user_id") @db.Uuid
  requestId  String?   @map("request_id")
  userAgent  String?   @map("user_agent") @db.Text
  ipAddress  String?   @map("ip_address")
  metadata   Json?
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([level, createdAt])
  @@index([source, createdAt])
  @@index([userId])
  @@index([resolvedAt])
  @@map("error_logs")
}
