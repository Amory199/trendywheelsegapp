# Inlined into the JS bundle by Expo at export/publish time (NODE_ENV=production).
# CRITICAL: `eas update` does NOT read eas.json build env — without this file
# (or exported shell vars) EXPO_PUBLIC_API_URL inlines as undefined and every
# OTA ships pointing at the localhost fallback → "Network request failed" on
# devices. (Root cause of the recurring login network errors, 2026-06-11.)
EXPO_PUBLIC_API_URL=https://api.trendywheelseg.com
EXPO_PUBLIC_SENTRY_DSN=https://93ce0c39e197aeac754e220bd597fc67@o4511359676252160.ingest.de.sentry.io/4511359744344144
