# TrendyWheels API

# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://trendywheels:trendywheels@localhost:5432/trendywheels

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# Twilio (optional in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=trendywheels
S3_REGION=us-east-1

# Sentry (optional)
SENTRY_DSN=

# SendGrid (optional)
SENDGRID_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
